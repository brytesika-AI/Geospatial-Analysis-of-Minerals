# ============================================================
# GeoExplorer AI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- LLM (HuggingFace Inference API) ---
# Get your token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# Which HF model to use for geological interpretation
# Options: meta-llama/Meta-Llama-3-8B-Instruct, mistralai/Mixtral-8x7B-Instruct-v0.1
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# --- Cloudflare ---
# Workers AI account ID + API token
CF_ACCOUNT_ID=your_account_id_here
CF_API_TOKEN=cfut_...

# Which CF Workers AI model to use
CF_LLM_MODEL=@cf/meta/llama-3-8b-instruct

# --- App Config ---
# Set to 1 to regenerate synthetic data even if cached data exists
FORCE_REFRESH=0

# Max predictions to show on heatmap (reduce if map is slow)
MAX_GRID_POINTS=5000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
