{
  "version": 2,
  "builds": [
    { "src": "api/predictions.py", "use": "@vercel/python" },
    { "src": "api/score.py",       "use": "@vercel/python" },
    { "src": "api/data.py",        "use": "@vercel/python" },
    { "src": "api/metadata.py",    "use": "@vercel/python" },
    { "src": "api/targets.py",     "use": "@vercel/python" },
    { "src": "api/health.py",      "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/predictions", "dest": "/api/predictions.py" },
    { "src": "/api/score",       "dest": "/api/score.py" },
    { "src": "/api/data",        "dest": "/api/data.py" },
    { "src": "/api/metadata",    "dest": "/api/metadata.py" },
    { "src": "/api/targets",     "dest": "/api/targets.py" },
    { "src": "/api/health",      "dest": "/api/health.py" },
    { "src": "/",                "dest": "/public/index.html" },
    { "src": "/(.*)",            "dest": "/public/$1" }
  ]
}
